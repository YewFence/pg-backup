[streaming-backup-server]
description = "Postgres server using streaming replication"
streaming_archiver = on
backup_method = postgres
streaming_conninfo = host=postgres user=streaming_barman dbname=postgres
slot_name = barman
create_slot = auto
conninfo = host=postgres user=barman dbname=postgres
minimum_redundancy = 1
retention_policy = RECOVERY WINDOW OF 7 DAYS

# 同一个 Barman host 可以备份多个 PostgreSQL。
# 推荐每个 PostgreSQL 一个独立的 .conf 文件，也可以在同一个文件里继续追加新的 server 段。
#
# [pg-report]
# description = "Report PostgreSQL using streaming replication"
# streaming_archiver = on
# backup_method = postgres
# streaming_conninfo = host=pg-report user=streaming_barman dbname=postgres
# slot_name = barman
# create_slot = auto
# conninfo = host=pg-report user=barman dbname=postgres
