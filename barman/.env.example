TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx
BARMAN_IMAGE=ghcr.io/yewfence/pg-backup/barman:latest

# 留空使用 barman-data 命名卷，也可以改成绝对路径绑定挂载
BARMAN_VOLUME=

# 容器内 barman 用户的数字 ID，宿主机绑定挂载时需要让目录 owner 匹配这两个值
BARMAN_UID=999
BARMAN_GID=999
BARMAN_FIX_OWNERSHIP=true

HEALTH_CHECK_PORT=8000
CHECK_INTERVAL=300
FAIL_THRESHOLD=3
