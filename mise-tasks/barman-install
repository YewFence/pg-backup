#!/usr/bin/env bash
#MISE description="初始化配置并部署 Barman（备份服务器首次部署）"
set -e
SOURCE_DIR="barman"
TARGET_DIR="../barman"
ENV_FILE="$SOURCE_DIR/.env"
CONF_FILE="$SOURCE_DIR/config/streaming-backup-server.conf"
CONF_EXAMPLE="$SOURCE_DIR/config/streaming-backup-server.conf.example"
CRONTAB_FILE="$SOURCE_DIR/config/barman.crontab"
CRONTAB_EXAMPLE="$SOURCE_DIR/config/barman.crontab.example"
PGPASS_FILE="$SOURCE_DIR/config/pgpass"

echo "=== Barman 备份端安装向导 ==="
echo ""

if [ -d "$TARGET_DIR" ]; then
    echo "错误：目标目录 $TARGET_DIR 已存在，请先删除或重命名。"
    exit 1
fi

echo "请输入 Tailscale Auth Key（TS_AUTHKEY，格式 tskey-auth-xxx）："
read -rs TS_AUTHKEY
echo ""
if [ -z "$TS_AUTHKEY" ]; then
    echo "错误：TS_AUTHKEY 不能为空。"
    exit 1
fi

cp "$SOURCE_DIR/.env.example" "$ENV_FILE"
sed -i "s|^TS_AUTHKEY=.*|TS_AUTHKEY=${TS_AUTHKEY}|" "$ENV_FILE"

echo "配置已写入 $ENV_FILE"

cat > "$PGPASS_FILE" << EOF
${PG_HOST}:5432:postgres:barman:${BARMAN_PASSWORD}
${PG_HOST}:5432:*:streaming_barman:${STREAMING_BARMAN_PASSWORD}
EOF
chmod 644 "$PGPASS_FILE"
echo "pgpass 已生成：$PGPASS_FILE"

# 如果 barman 服务器配置不存在，从 example 复制并替换 host
if [ ! -f "$CONF_FILE" ] && [ -f "$CONF_EXAMPLE" ]; then
    sed "/^[[:space:]]*#/! s/host=[^ ]*/host=${PG_HOST}/" "$CONF_EXAMPLE" > "$CONF_FILE"
    echo "Barman 服务器配置已生成：$CONF_FILE（host=${PG_HOST}） 请自行填入需要备份的 PostgreSQL 服务器信息"
fi

# 如果 crontab 不存在，从 example 复制
if [ ! -f "$CRONTAB_FILE" ] && [ -f "$CRONTAB_EXAMPLE" ]; then
    cp "$CRONTAB_EXAMPLE" "$CRONTAB_FILE"
    echo "定时任务配置已生成：$CRONTAB_FILE"
fi

echo ""
echo "移动服务目录到 $TARGET_DIR..."
cp -r "$SOURCE_DIR" "$TARGET_DIR"
echo ""
echo "✓ 完成！Barman 备份服务已部署到 $TARGET_DIR"
echo ""
echo "启动命令："
echo "  cd $TARGET_DIR && docker compose up -d"
echo ""
echo "启动后可用以下命令验证："
echo "  docker exec -it barman barman check all"
