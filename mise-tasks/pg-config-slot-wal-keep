#!/usr/bin/env bash
#MISE description="配置 PG 复制槽 WAL 保留上限"
#USAGE arg "[size]" help="复制槽 WAL 保留上限，例如 512MB、5GB、20GB、-1"
#USAGE flag "--apply" help="写入配置文件"
#USAGE flag "--no-reload" help="写入后不自动重载 PostgreSQL 配置"
#USAGE flag "--dir <dir>" help="pg-prod 实例目录" env="PG_INSTANCE_DIR"
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT="$ROOT_DIR/pg-prod/scripts/pg-config-slot-wal-keep"
DEFAULT_INSTANCE_DIR="$ROOT_DIR/../pg"
args=()
passthrough=()
using_mise_usage="false"
has_passthrough_dir="false"

if [ -n "${usage_size+x}" ] || [ -n "${usage_apply+x}" ] || [ -n "${usage_no_reload+x}" ] || [ -n "${usage_dir+x}" ]; then
    using_mise_usage="true"
fi

if [ "$using_mise_usage" = "false" ]; then
    passthrough=("$@")
    for arg in "$@"; do
        if [ "$arg" = "--dir" ]; then
            has_passthrough_dir="true"
        fi
    done
fi

if [ -n "${usage_size:-}" ]; then
    args+=("${usage_size}")
fi
if [ "${usage_apply:-false}" = "true" ]; then
    args+=(--apply)
fi
if [ "${usage_no_reload:-false}" = "true" ]; then
    args+=(--no-reload)
fi
if [ -n "${usage_dir:-}" ]; then
    args+=(--dir "${usage_dir}")
elif [ -n "${PG_INSTANCE_DIR:-}" ]; then
    args+=(--dir "${PG_INSTANCE_DIR}")
elif [ "$has_passthrough_dir" = "false" ]; then
    args+=(--dir "$DEFAULT_INSTANCE_DIR")
fi

exec "$SCRIPT" "${args[@]}" "${passthrough[@]}"
